# SeaTable (required)
SEATABLE_SERVER_URL=https://cloud.seatable.io
SEATABLE_EXTERNAL_LINK_URL=
SEATABLE_API_TOKEN=
SEATABLE_ACCOUNT_TOKEN=
SEATABLE_WORKSPACE_ID=
SEATABLE_BASE_NAME=
SEATABLE_BASE_UUID=
SEATABLE_TABLE_NAME=Archive

# Shared password required for uploads
UPLOAD_PASSWORD=

# Optional custom column names in SeaTable
SEATABLE_COL_ID=id
SEATABLE_COL_TITLE=title
SEATABLE_COL_DESCRIPTION=description
SEATABLE_COL_CITY=city
SEATABLE_COL_NEIGHBORHOOD=neighborhood
SEATABLE_COL_LAT=lat
SEATABLE_COL_LNG=lng
SEATABLE_COL_TAKEN_AT=taken_at
SEATABLE_COL_CREATED_AT=created_at
SEATABLE_COL_IMAGE_FILE=image
SEATABLE_COL_IMAGE_URL=image_url

# Legacy base64 fallback (only if no image column is available)
SEATABLE_ENABLE_LEGACY_BASE64_FALLBACK=false
SEATABLE_MAX_IMAGE_BASE64_LENGTH=60000
SEATABLE_SAFE_BASE64_CAP=60000
SEATABLE_COL_IMAGE_BASE64=image_base64
SEATABLE_COL_IMAGE_MIME=image_mime
SEATABLE_COL_IMAGE_NAME=image_name
